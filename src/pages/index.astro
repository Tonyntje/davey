---
import Layout from '../layouts/Layout.astro';
import HeroSlider from '../components/HeroSlider';
import Reviews from '../components/Reviews.astro';
---

<Layout title="Home">
  {/* Hero Section */}
  <HeroSlider client:load />

  {/* Intro Section - Tegelwerk met passie en precisie */}
  <section id="intro" class="py-20 bg-brand-beige dark:bg-gray-800 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl md:text-5xl font-playfair font-black text-black dark:text-white mb-6 leading-tight">
          Tegelwerk met passie en precisie
        </h2>
        <h3 class="text-xl font-bold mb-6 dark:text-gray-200">
          Maak kennis met Duif Tegelwerken
        </h3>
        <p class="text-base text-gray-700 dark:text-gray-300 leading-relaxed max-w-lg mb-8">
          Mijn naam is Davey van Duivenbode. Na negen jaar met veel plezier in loondienst te hebben gewerkt, besloot ik in 2023 de sprong te wagen: de start van mijn eigen bedrijf, Duif Tegelwerken. <br><br>
          Tijdens mijn jaren in het vak heb ik niet alleen mijn diploma's (Niveau 2 en 3) behaald, maar vooral ontdekt waar mijn daadwerkelijke passie ligt: het leveren van dé perfecte voeg, een strak badkamer design, en een complete luxe badkamer. Ik zorg dat het tot in de puntjes verzorgd is.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 items-center">
             <a href="/contact" class="bg-brand-black text-white px-8 py-3 font-semibold text-sm rounded-sm hover:opacity-90 inline-flex items-center dark:bg-white dark:text-brand-black transition-all">
                Neem contact op 
                <svg class="ml-2 w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                   <path d="M12 2C8 2 5 5 5 9c0 1.25.32 2.42.88 3.42C7 14.5 9 17 12 21c3-4 5-6.5 6.12-8.58C18.68 11.42 19 10.25 19 9c0-4-3-7-7-7zm0 10c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
                </svg>
             </a>
             <a href="tel:0625123794" class="text-sm font-bold underline dark:text-gray-300">Of bel 06 25 12 3794</a>
        </div>
      </div>
      <div class="relative h-96 w-full group">
        <img 
          src="https://images.unsplash.com/photo-1513694203232-719a280e022f?q=80&w=2669&auto=format&fit=crop" 
          alt="Davey van Duivenbode working on tiles" 
          class="absolute inset-0 w-full h-full object-cover shadow-2xl transition-transform duration-500 group-hover:scale-105"
        />
        <div class="absolute inset-0 ring-1 ring-inset ring-black/10"></div>
      </div>
    </div>
  </section>

  {/* Speciality Section - Het detail zit in de hoek */}
  <section id="specialiteit" class="py-20 bg-white dark:bg-gray-900 overflow-hidden relative transition-colors duration-300">
     {/* Decorative subtle background tile pattern */}
     <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image: radial-gradient(circle at center, black 1px, transparent 1px); background-size: 20px 20px;"></div>
     
     <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-2 gap-12 items-center relative z-10">
      
      {/* Reverse order on mobile */}
      <div class="order-2 md:order-1 relative h-96 w-full lg:h-[32rem]">
         <img 
          src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?q=80&w=2670&auto=format&fit=crop" 
          alt="Bathroom corner detail" 
          class="absolute inset-0 w-full h-full object-cover shadow-lg"
         />
      </div>

      <div class="order-1 md:order-2">
        <h3 class="text-lg font-bold uppercase tracking-widest text-gray-500 mb-2 dark:text-gray-400">
           DE SPECIALITEIT
        </h3>
        <h2 class="text-4xl md:text-5xl font-playfair font-black text-black dark:text-white mb-6 leading-tight">
          Het detail zit in de hoek
        </h2>
        <div class="space-y-6 text-gray-700 dark:text-gray-300 text-base leading-relaxed">
            <p><strong>Verfijnde afwerking. Wat Duif Tegelwerken onderscheidt?</strong></p>
            <p>Mijn oog voor detail, en dan met name bij de afwerking van hoeken.</p>
            <p>Waar anderen kiezen voor de makkelijke weg, neem ik de tijd voor perfect afgeronde hoeken en verstekwerk. Het zijn juist de kleine details die van een standaard klus een luxe resultaat maken.</p>
        </div>
      </div>
    </div>
  </section>

  {/* Werwijze Section */}
  <section id="werkwijze" class="py-20 bg-brand-beige dark:bg-gray-800 transition-colors duration-300">
     <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      
      <div>
        <h2 class="text-4xl md:text-5xl font-playfair font-black text-black dark:text-white mb-8 leading-tight">
          Mijn werkwijze
        </h2>
        <div class="space-y-6 text-gray-700 dark:text-gray-300 text-base leading-relaxed mb-8">
            <p><strong>Eerlijk advies en korte lijntjes.<br />Ik geloof in helderheid.</strong></p>
            <p>Geen ingewikkelde verhalen, maar gewoon goede communicatie en doen wat je belooft.</p>
            <p>Afspraak is bij mij ook echt afspraak.</p>
            <p>Omdat ik samenwerk met vaste partners, kan ik je ook volledig ontzorgen bij de realisatie van een complete badkamer.</p>
            <p>Ik werk voornamelijk in Den Haag en omstreken.</p>
        </div>
        <a href="/contact" class="bg-brand-black text-white px-8 py-3 font-semibold text-sm rounded-sm hover:opacity-90 inline-flex items-center dark:bg-white dark:text-brand-black transition-all">
            Neem contact op 
            <svg class="ml-2 w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
               <path d="M12 2C8 2 5 5 5 9c0 1.25.32 2.42.88 3.42C7 14.5 9 17 12 21c3-4 5-6.5 6.12-8.58C18.68 11.42 19 10.25 19 9c0-4-3-7-7-7zm0 10c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
            </svg>
        </a>
      </div>

       <div class="relative h-96 w-full lg:h-[32rem]">
         <img 
          src="https://images.unsplash.com/photo-1581094794329-c8112a89af12?q=80&w=2574&auto=format&fit=crop" 
          alt="Floor tiles pattern laying" 
          class="absolute inset-0 w-full h-full object-cover shadow-xl"
         />
      </div>

    </div>
  </section>

  {/* Reviews Section */}
  <Reviews />
</Layout>
