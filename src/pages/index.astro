---
import Layout from "../layouts/Layout.astro";
import HeroSlider from "../components/HeroSlider";
import Reviews from "../components/Reviews.astro";
---

<Layout title="Home">
  {/* Hero Section - boxed slider */}
  <HeroSlider client:load />

  {/* Intro Section - Tegelwerk met passie en precisie */}
  <section id="intro" class="py-20">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
    >
      <div>
        <h2 class="text-3xl md:text-4xl text-black mb-4 leading-tight">
          Tegelwerk met passie en precisie
        </h2>
        <h3 class="font-roboto text-black text-lg mb-6 text-gray-900">
          Maak kennis met Duif Tegelwerken
        </h3>
        <p class="text-sm text-gray-700 leading-relaxed max-w-lg mb-8">
          Mijn naam is Davey van Duivenbode. Na negen jaar met veel plezier in
          loondienst te hebben gewerkt, besloot ik in 2023 de sprong te wagen:
          de start van mijn eigen bedrijf, Duif Tegelwerken. <br /><br />
          Tijdens mijn jaren in het vak heb ik niet alleen mijn diploma's (Niveau
          2 en 3) behaald, maar vooral ontdekt waar mijn kracht ligt: het leveren
          van echt vakwerk waar mensen jarenlang van kunnen genieten. Of het nu gaat
          om een modern toilet, een strakke keukenvloer of een complete luxe badkamer,
          ik zorg dat het tot in de puntjes verzorgd is.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 items-start">
          <a
            href="/contact"
            class="bg-brand-black text-white px-6 py-3 font-semibold text-sm rounded-sm hover:opacity-90 inline-flex items-center transition-all"
          >
            Neem contact op
            <img src="/pigeon-svg.svg" alt="" class="ml-2 w-4 h-4 invert" />
          </a>
          <a
            href="tel:0625123794"
            class="text-sm font-bold underline text-gray-900 hover:text-gray-600 py-3"
            >of bekijk galerij</a
          >
        </div>
      </div>
      <div class="relative h-80 md:h-96 w-full">
        <img
          src="/image2.webp"
          alt="Davey van Duivenbode working on tiles"
          class="w-full h-full object-cover shadow-xl"
        />
      </div>
    </div>
  </section>

  {/* Specialiteit Section - photo left, text right — full width */}
  <section id="specialiteit" class="py-20 bg-[#efefef]">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-2 gap-0 items-stretch"
    >
      {/* Photo left */}
      <div class="relative min-h-[400px]">
        <img
          src="/image4.webp"
          alt="Bathroom corner detail"
          class="w-full h-full object-cover"
        />
      </div>

      {/* Text right */}
      <div class="flex flex-col justify-center p-8 md:p-12 lg:p-16">
        <h3
          class="font-[roboto] text-sm font-bold uppercase tracking-widest text-gray-500 mb-2"
        >
          De Specialiteit
        </h3>
        <h2 class="text-3xl md:text-4xl text-black mb-6 leading-tight">
          Het detail zit in de hoek
        </h2>
        <div class="space-y-4 text-gray-700 text-sm leading-relaxed">
          <p>
            <strong
              >Verfijnde afwerking. Wat Duif Tegelwerken onderscheidt?</strong
            >
          </p>
          <p>
            Mijn oog voor detail, en dan met name bij de afwerking van hoeken.
          </p>
          <p>
            Waar anderen kiezen voor de makkelijke weg, neem ik de tijd voor
            perfect afgeronde hoekjes en verstekwerk. Het zijn juist de kleine
            details die van een standaard klus een luxe resultaat maken.
          </p>
        </div>
      </div>
    </div>
  </section>

  {
    /* Werkwijze Section — BOXED: text + image side by side inside a contained card */
  }
  <section id="werkwijze" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="bg-brand-beige shadow-md grid grid-cols-1 md:grid-cols-2 items-stretch overflow-hidden"
      >
        {/* Text left */}
        <div class="p-8 md:p-12 flex flex-col justify-center">
          <h2 class="text-3xl md:text-4xl text-black mb-6 leading-tight italic">
            Mijn werkwijze
          </h2>
          <div class="space-y-4 text-gray-700 text-sm leading-relaxed mb-8">
            <p>
              <strong
                >Eerlijk advies en korte lijntjes.<br />Ik geloof in helderheid.</strong
              >
            </p>
            <p>
              Geen ingewikkelde verhalen, maar gewoon goede communicatie en doen
              wat je belooft.
            </p>
            <p>Afspraak is bij mij ook echt afspraak.</p>
            <p>
              Omdat ik samenwerk met vaste partners, kan ik je ook volledig
              ontzorgen bij de realisatie van een complete badkamer.
            </p>
            <p>Ik werk voornamelijk in Den Haag en omstreken.</p>
          </div>
          <div>
            <a
              href="/contact"
              class="bg-brand-black text-white px-6 py-3 font-semibold text-sm rounded-sm hover:bg-gray-800 transition-colors inline-flex items-center"
            >
              Neem contact op
              <img src="/pigeon-svg.svg" alt="" class="ml-2 w-4 h-4 invert" />
            </a>
          </div>
        </div>

        {/* Image right */}
        <div class="relative min-h-[400px]">
          <img
            src="/image22.webp"
            alt="Floor tiles pattern laying"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  {/* Reviews Section */}
  <Reviews />
</Layout>
