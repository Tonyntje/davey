---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import GalleryLightbox from "../components/GalleryLightbox";

// Organize images into project categories for a professional gallery
const projects = [
  {
    title: "Complete badkamer renovatie",
    description:
      "Een volledige badkamerrenovatie met grote vloertegels, wandtegels en een inloopdouche.",
    images: ["/image3.webp", "/image4.webp", "/image5.webp"],
  },
  {
    title: "Keuken wandtegels",
    description:
      "Strakke wandtegels achter het keukenblad, tot in de punt afgewerkt.",
    images: ["/image2.webp", "/image6.webp", "/image7.webp"],
  },
  {
    title: "Vloerwerk",
    description:
      "Diverse vloerprojecten met verschillende patronen en materialen.",
    images: ["/image22.webp", "/image20.webp", "/image26.webp"],
  },
  {
    title: "Toilet & kleine ruimtes",
    description: "Ook kleine ruimtes verdienen de beste afwerking.",
    images: ["/image8.webp", "/image9.webp", "/image10.webp"],
  },
];

// All images for the masonry grid
const allImages = [
  { src: "/image0.webp", alt: "Tegelzetter aan het werk" },
  { src: "/image1.webp", alt: "Badkamer wandtegels" },
  { src: "/image2.webp", alt: "Davey van Duivenbode tegelt een wand" },
  { src: "/image3.webp", alt: "Keuken achterwand project" },
  { src: "/image4.webp", alt: "Badkamer hoekafwerking" },
  { src: "/image5.webp", alt: "Doucheruimte met grote tegels" },
  { src: "/image6.webp", alt: "Keukenwand tegelwerk" },
  { src: "/image7.webp", alt: "Keuken spatwand detail" },
  { src: "/image8.webp", alt: "Toilet renovatie" },
  { src: "/image9.webp", alt: "Kleine ruimte tegelwerk" },
  { src: "/image10.webp", alt: "Tegelwerk afwerking" },
  { src: "/image11.webp", alt: "Vloertegel patroon" },
  { src: "/image12.webp", alt: "Badkamer vloer" },
  { src: "/image13.webp", alt: "Tegelwerk detail" },
  { src: "/image14.webp", alt: "Wandtegel project" },
  { src: "/image15.webp", alt: "Vloer afwerking" },
  { src: "/image16.webp", alt: "Badkamer renovatie" },
  { src: "/image17.webp", alt: "Tegels in patroon" },
  { src: "/image19.webp", alt: "Douche tegelwerk" },
  { src: "/image20.webp", alt: "Vloerwerk project" },
  { src: "/image21.webp", alt: "Tegelwerk overzicht" },
  { src: "/image22.webp", alt: "Vloertegels in visgraatpatroon" },
  { src: "/image23.webp", alt: "Tegelwerk resultaat" },
  { src: "/image24.webp", alt: "Afgewerkte badkamer" },
  { src: "/image25.webp", alt: "Tegelwerk hoekdetail" },
  { src: "/image26.webp", alt: "Vloer tegelproject" },
  { src: "/image27.webp", alt: "Wandtegels resultaat" },
  { src: "/image28.webp", alt: "Keuken tegelwerk" },
  { src: "/image29.webp", alt: "Toilet tegelproject" },
  { src: "/image30.webp", alt: "Afgewerkt tegelproject" },
];
---

<Layout
  title="Projecten"
  description="Bekijk de projecten van Duif Tegelwerken. Van badkamerrenovaties tot strakke keukenwanden en prachtige vloeren in Den Haag."
  canonicalPath="/gallerij"
>
  {/* Page Header */}
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-5xl md:text-6xl text-black mb-6">Projecten</h1>
          <h2 class="text-lg font-bold mb-6 text-gray-900">
            Een selectie van mijn werk
          </h2>
          <p class="text-sm text-gray-700 leading-relaxed max-w-lg mb-8">
            Hieronder vindt u een selectie van recente projecten. Van complete
            badkamerrenovaties tot strakke keukenwanden en prachtige vloeren.
            Elk project wordt met dezelfde precisie en oog voor detail
            uitgevoerd. Bekijk de foto's en laat u inspireren voor uw eigen
            project.
          </p>
          <a
            href="/contact"
            class="bg-brand-black text-white px-6 py-3 font-semibold text-sm rounded-sm hover:opacity-90 inline-flex items-center transition-all"
          >
            Neem contact op
            <img
              src="/pigeon-svg.svg"
              alt=""
              class="ml-2 w-4 h-4 invert"
              aria-hidden="true"
            />
          </a>
        </div>

        <div class="relative h-80 md:h-96 w-full">
          <img
            src="/image3-sm.webp"
            srcset="/image3-sm.webp 420w, /image3.webp 800w"
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt="Keuken achterwand project door Duif Tegelwerken"
            class="w-full h-full object-cover shadow-xl"
            loading="eager"
            decoding="async"
            width="420"
            height="512"
          />
        </div>
      </div>
    </div>
  </section>

  {/* Full Gallery Grid */}
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl text-black mb-2 text-center">
        Alle foto's
      </h2>
      <p class="text-sm text-gray-600 mb-12 text-center">
        Een overzicht van ons vakmanschap
      </p>

      <GalleryLightbox images={allImages} client:load />
    </div>
  </section>

  {/* CTA Section */}
  <section class="py-20 bg-brand-beige">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl text-black mb-6">
        Geïnspireerd geraakt?
      </h2>
      <p class="text-sm text-gray-700 leading-relaxed mb-8 max-w-lg mx-auto">
        Heeft u een soortgelijk project in gedachten of wilt u meer weten over
        de mogelijkheden? Neem gerust contact op voor een vrijblijvend
        adviesgesprek.
      </p>
      <a
        href="/contact"
        class="bg-brand-black text-white px-8 py-3 font-semibold text-sm rounded-sm hover:opacity-90 inline-flex items-center transition-all"
      >
        Neem contact op
        <img
          src="/pigeon-svg.svg"
          alt=""
          class="ml-2 w-4 h-4 invert"
          aria-hidden="true"
        />
      </a>
    </div>
  </section>
</Layout>
