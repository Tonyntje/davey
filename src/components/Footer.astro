---
const year = new Date().getFullYear();
---

<footer class="bg-brand-beige border-t border-gray-200 dark:bg-gray-900 dark:border-gray-800 pt-20 pb-8 mt-auto relative overflow-hidden">
  
  {/* Pigeon silhouettes on left and right for desktop (subtle background absolute elements?) - optional but requested 'dynamic approach' or aesthetic */}
  <div class="hidden lg:block absolute bottom-0 -left-10 text-gray-200 dark:text-gray-800 opacity-50 transform scale-150">
    <svg width="200" height="200" viewBox="0 0 24 24" fill="currentColor">
       <path d="M12 2C8 2 5 5 5 9c0 1.25.32 2.42.88 3.42C7 14.5 9 17 12 21c3-4 5-6.5 6.12-8.58C18.68 11.42 19 10.25 19 9c0-4-3-7-7-7zm0 10c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
    </svg>
  </div>
  <div class="hidden lg:block absolute bottom-0 -right-10 text-gray-200 dark:text-gray-800 opacity-50 transform scale-[1.5] scale-x-[-1]">
    <svg width="200" height="200" viewBox="0 0 24 24" fill="currentColor">
       <path d="M12 2C8 2 5 5 5 9c0 1.25.32 2.42.88 3.42C7 14.5 9 17 12 21c3-4 5-6.5 6.12-8.58C18.68 11.42 19 10.25 19 9c0-4-3-7-7-7zm0 10c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left">
      
      {/* Column 1: Navigation */}
      <div class="md:pr-8">
        <h3 class="font-playfair font-black text-2xl mb-8 uppercase tracking-widest border-b border-black dark:border-white inline-block md:block dark:text-white">NAVIGATIE</h3>
        <ul class="space-y-3 text-sm font-medium">
          <li><a href="/" class="hover:underline dark:text-gray-300">Home</a></li>
          <li><a href="/#projecten" class="hover:underline dark:text-gray-300">Projecten</a></li>
          <li><a href="/#over-mij" class="hover:underline dark:text-gray-300">Over mij</a></li>
          <li><a href="/contact" class="hover:underline dark:text-gray-300">Contact</a></li>
          <li><a href="/sitemap" class="hover:underline dark:text-gray-300">Sitemap</a></li>
        </ul>
      </div>

      {/* Column 2: Logo */}
      <div class="flex flex-col items-center justify-center -mt-4 border-t md:border-none border-gray-300 dark:border-gray-700 pt-8 md:pt-0">
          <div class="flex space-x-2 mb-2 justify-center">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="text-black dark:text-white">
              <path d="M12 2C8 2 5 5 5 9c0 1.25.32 2.42.88 3.42C7 14.5 9 17 12 21c3-4 5-6.5 6.12-8.58C18.68 11.42 19 10.25 19 9c0-4-3-7-7-7zm0 10c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
            </svg>
            <div class="border-[2px] border-black dark:border-white w-12 h-12 flex flex-wrap content-between p-1">
                <span class="w-4 h-4 border border-black dark:border-white"></span>
                <span class="w-4 h-4 border border-black dark:border-white bg-black dark:bg-white"></span>
                <span class="w-4 h-4 border border-black dark:border-white"></span>
                <span class="w-4 h-4 border border-black dark:border-white bg-black dark:bg-white"></span>
            </div>
            <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="text-black dark:text-white transform scale-x-[-1]">
              <path d="M12 2C8 2 5 5 5 9c0 1.25.32 2.42.88 3.42C7 14.5 9 17 12 21c3-4 5-6.5 6.12-8.58C18.68 11.42 19 10.25 19 9c0-4-3-7-7-7zm0 10c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
            </svg>
          </div>
          <span class="font-playfair font-black text-2xl tracking-[0.2em] mt-2 text-black dark:text-white border-b-2 border-black dark:border-white pb-2">
             DUIF TEGELWERKEN
          </span>
          <div class="flex items-center mt-6 space-x-6 text-xs font-bold dark:text-gray-300 justify-center">
            <span class="flex items-center">
              <span class="mr-2">📧</span> INFO@DUIFTEGELWERKEN.NL
            </span>
            <span class="flex items-center">
              <span class="mr-2">📞</span> 06 - 25 12 3794
            </span>
          </div>
      </div>

      {/* Column 3: Contact */}
      <div class="md:pl-8 border-t md:border-none border-gray-300 dark:border-gray-700 pt-8 md:pt-0">
        <h3 class="font-playfair font-black text-2xl mb-8 uppercase tracking-widest border-b border-black dark:border-white inline-block md:block dark:text-white text-right md:text-left">CONTACT</h3>
        <p class="text-sm mb-4 dark:text-gray-300 text-right md:text-left">Voer uw nummer of email in, dan neem ik zo spoedig mogelijk contact met u op!</p>
        
        <form class="flex flex-col items-end md:items-start space-y-3" onsubmit="event.preventDefault(); alert('Bedankt! We nemen z.s.m. contact met u op.');">
          <input 
            type="text" 
            placeholder="Voor je contact informatie in..." 
            required
            class="w-full bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-black dark:text-white dark:focus:ring-white transition-colors"
          />
          <button type="submit" class="bg-brand-black text-white px-8 py-3 font-semibold text-sm rounded-sm hover:bg-gray-800 dark:bg-white dark:text-brand-black dark:hover:bg-gray-200 transition-colors inline-flex items-center transition-all active:scale-95">
            Verzend
            <svg class="ml-2 w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C8 2 5 5 5 9c0 1.25.32 2.42.88 3.42C7 14.5 9 17 12 21c3-4 5-6.5 6.12-8.58C18.68 11.42 19 10.25 19 9c0-4-3-7-7-7zm0 10c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
            </svg>
          </button>
        </form>

      </div>
    </div>

    {/* Bottom Bar */}
    <div class="mt-20 pt-6 border-t border-gray-300 dark:border-gray-700 flex flex-col md:flex-row justify-between items-center text-xs dark:text-gray-400">
      <p>&copy; <strong>Duif Tegelwerken</strong> {year}. Alle rechten voorbehouden.</p>
      <div class="flex space-x-4 mt-4 md:mt-0">
        <a href="#" class="hover:underline">Algemene voorwaarden</a>
        <span>|</span>
        <a href="#" class="hover:underline">Privacy verklaring</a>
      </div>
    </div>
  </div>
</footer>
