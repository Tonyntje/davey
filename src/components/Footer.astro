---
const year = new Date().getFullYear();
---

<footer
  class="bg-brand-beige border-t border-gray-200 pt-20 pb-8 mt-auto relative overflow-hidden"
  role="contentinfo"
  aria-label="Sitefooter"
>
  {/* Big transparent pigeons on left and right */}
  <div
    class="hidden md:block absolute bottom-8 left-4 opacity-[0.06] pointer-events-none"
  >
    <img
      src="/pigeon-svg.svg"
      alt=""
      class="w-[400px] h-auto"
      aria-hidden="true"
      loading="lazy"
    />
  </div>
  <div
    class="hidden md:block absolute bottom-8 right-4 opacity-[0.06] pointer-events-none"
    style="transform: scaleX(-1);"
  >
    <img
      src="/pigeon-svg.svg"
      alt=""
      class="w-[400px] h-auto"
      aria-hidden="true"
      loading="lazy"
    />
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left"
    >
      {/* Column 1: Navigation */}
      <div class="md:pr-8 mt-30">
        <h3
          class="text-2xl mb-8 uppercase tracking-widest border-b-2 border-black inline-block pb-1"
        >
          NAVIGATIE
        </h3>
        <nav
          class="grid grid-cols-2 gap-x-8 gap-y-3 text-sm font-medium"
          aria-label="Voetnavigatie"
        >
          <a href="/" class="hover:underline">Home</a>
          <a href="/over-mij" class="hover:underline">Over mij</a>
          <a href="/gallerij" class="hover:underline">Gallery</a>
          <a href="/contact" class="hover:underline">Contact</a>
          <a href="/sitemap" class="hover:underline">Sitemap</a>
        </nav>
      </div>

      {/* Column 2: Logo + contact info with white background */}
      <div
        class="flex flex-col justify-center border-t md:border-none border-gray-300 pt-8 md:pt-0"
      >
        <img
          src="/Transparant.svg"
          alt="Duif Tegelwerken logo"
          class="h-60 mb-6"
          loading="lazy"
        />
        <div
          class="bg-white px-6 py-3 flex items-center space-x-6 text-xs font-bold shadow-sm"
        >
          <a
            href="mailto:info@duiftegelwerken.nl"
            class="flex items-center hover:underline"
          >
            <img
              src="/at-solid-full.svg"
              loading="lazy"
              alt="Duif Tegelwerken"
              class="w-3 h-3 mr-2"
            />
            INFO@DUIFTEGELWERKEN.NL
          </a>
          <a href="tel:0625123794" class="flex items-center hover:underline">
            <img src="/phone-solid-full.svg" alt="" class="w-3 h-3 mr-2" />
            06 - 25 12 3794
          </a>
        </div>
      </div>

      {/* Column 3: Contact */}
      <div
        class="mt-30 md:pl-8 border-t md:border-none border-gray-300 pt-8 md:pt-0"
      >
        <h3
          class="text-2xl mb-6 uppercase tracking-widest border-b-2 border-black inline-block pb-1"
        >
          CONTACT
        </h3>
        <p class="text-sm mb-4">
          Voer uw nummer of email in, dan neem ik zo spoedig mogelijk contact
          met u op!
        </p>

        <form
          class="flex flex-col space-y-3"
          aria-label="Snel contactformulier"
          onsubmit="event.preventDefault(); alert('Bedankt! We nemen z.s.m. contact met u op.');"
        >
          <label for="footer-contact" class="sr-only"
            >Uw e-mail of telefoonnummer</label
          >
          <input
            id="footer-contact"
            type="text"
            placeholder="Voor je contact informatie in..."
            required
            autocomplete="email"
            class="w-full bg-white border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-black transition-colors"
          />
          <div class="flex justify-end">
            <button
              type="submit"
              class="bg-brand-black text-white px-8 py-3 font-semibold text-sm rounded-sm hover:bg-gray-800 transition-colors inline-flex items-center active:scale-95"
            >
              Verzend
              <img
                src="/pigeon-svg.svg"
                alt=""
                class="ml-2 w-4 h-4 invert"
                loading="lazy"
              />
            </button>
          </div>
        </form>
      </div>
    </div>

    {/* Bottom Bar */}
    <div
      class="mt-20 pt-6 border-t border-gray-300 flex flex-col md:flex-row justify-between items-center text-xs text-gray-800"
    >
      <p>
        &copy; <strong>Duif Tegelwerken</strong>
        {year}. Alle rechten voorbehouden.
      </p>
      <div class="flex space-x-4 mt-4 md:mt-0">
        <a href="#" class="hover:underline">Algemene voorwaarden</a>
        <span>|</span>
        <a href="#" class="hover:underline">Privacy verklaring</a>
      </div>
    </div>
  </div>
</footer>
