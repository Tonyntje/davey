---
const reviews = [
  {
    name: "Harry van Loon",
    rating: 5,
    text: "Lekker gewerkt pik! Super blij met de werkzaamheden die Davey verricht heeft. Alles zo mooi.",
    image: "https://i.pravatar.cc/150?img=11"
  },
  {
    name: "Guido Toppas",
    rating: 5,
    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Curabitur aliquet vehicula lacinia. Aenean non mi ultricies, iaculis felis sit amet, imperdiet ipsum. Praesent egestas ligula ac dui euismod.",
    image: "https://i.pravatar.cc/150?img=12"
  },
  {
    name: "Danny de Vries",
    rating: 5,
    text: "Lekker gewerkt pik! Super blij met de werkzaamheden die Davey verricht heeft. Alles zo mooi.",
    image: "https://i.pravatar.cc/150?img=13"
  }
];
---

<section id="reviews" class="py-20 bg-white dark:bg-gray-900 border-t border-gray-100 dark:border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    
    <h2 class="text-3xl md:text-4xl font-playfair font-black text-black dark:text-white mb-2">
      Wat denken anderen over Duif Tegelwerken?
    </h2>
    <div class="flex items-center justify-center mb-12">
        <span class="text-lg font-bold mr-2 dark:text-gray-300">Reviews van</span>
        {/* Simple Google SVG mock */}
        <div class="flex font-bold text-xl tracking-tighter">
            <span class="text-[#4285F4]">G</span>
            <span class="text-[#EA4335]">o</span>
            <span class="text-[#FBBC05]">o</span>
            <span class="text-[#4285F4]">g</span>
            <span class="text-[#34A853]">l</span>
            <span class="text-[#EA4335]">e</span>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviews.map((r) => (
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-8 text-left shadow-sm">
          <div class="flex items-center space-x-4 mb-4">
            <img src={r.image} alt={r.name} class="w-12 h-12 rounded-full object-cover shadow-sm bg-gray-100" />
            <div>
              <h3 class="font-playfair font-bold text-xl dark:text-white">{r.name}</h3>
              <div class="flex text-[#FBBC05] text-sm mt-1">
                {'★'.repeat(r.rating)}
              </div>
            </div>
          </div>
          <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
            {r.text}
          </p>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#" class="bg-brand-black text-white dark:bg-white dark:text-brand-black px-8 py-3 font-semibold text-sm rounded-sm whitespace-nowrap inline-flex items-center">
        Review achterlaten
        {/* pigeon tail svg or anything */}
        <svg class="ml-2 w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
           <path d="M12 2C8 2 5 5 5 9c0 1.25.32 2.42.88 3.42C7 14.5 9 17 12 21c3-4 5-6.5 6.12-8.58C18.68 11.42 19 10.25 19 9c0-4-3-7-7-7zm0 10c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
        </svg>
      </a>
      <a href="#" class="text-sm underline font-bold dark:text-gray-300">
        of bekijk alle reviews
      </a>
    </div>

  </div>
</section>
